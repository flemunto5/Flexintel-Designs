<?php

namespace App\Console\Commands;

use Illuminate\Console\Command;
use App\Services\MpesaService;

class TestMpesaStkPush extends Command
{
    protected $signature = 'mpesa:test-stk
                            {phone : Phone number in format 2547XXXXXXXX}
                            {amount=1 : Amount in KES (default: 1)}';

    protected $description = 'Send a test M-PESA STK push to a phone number';

    public function handle(MpesaService $mpesa): int
    {
        $phone  = $this->argument('phone');
        $amount = (int) $this->argument('amount');

        $this->info("Sending STK Push to {$phone} for KES {$amount}...");

        try {
            $result = $mpesa->stkPush(
                phone:       $phone,
                amount:      $amount,
                reference:   'TEST-' . now()->format('YmdHis'),
                description: 'Flexintel Designs – Test Payment'
            );

            $this->table(
                ['Field', 'Value'],
                collect($result)->map(fn($v, $k) => [$k, is_array($v) ? json_encode($v) : $v])->values()->toArray()
            );

            if (($result['ResponseCode'] ?? null) === '0') {
                $this->info('✅ STK Push sent successfully! Check the phone for the M-PESA prompt.');
                return Command::SUCCESS;
            }

            $this->error('❌ STK Push failed: ' . ($result['errorMessage'] ?? 'Unknown error'));
            return Command::FAILURE;

        } catch (\Throwable $e) {
            $this->error('Exception: ' . $e->getMessage());
            return Command::FAILURE;
        }
    }
}
